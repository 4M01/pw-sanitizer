{
  "name": "pw-sanitizer",
  "version": "0.1.0",
  "description": "Post-process Playwright HTML reports and trace files to redact secrets and remove noisy steps",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "playwright-sanitizer": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./teardown": {
      "types": "./dist/teardown.d.ts",
      "import": "./dist/teardown.js",
      "require": "./dist/teardown.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "playwright",
    "sanitizer",
    "redact",
    "secrets",
    "html-report",
    "trace"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/4M01/pw-sanitizer.git"
  },
  "homepage": "https://github.com/4M01/pw-sanitizer#readme",
  "bugs": {
    "url": "https://github.com/4M01/pw-sanitizer/issues"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "glob": "^11.0.0",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "peerDependencies": {
    "sharp": ">=0.33.0"
  },
  "peerDependenciesMeta": {
    "sharp": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist"
  ]
}